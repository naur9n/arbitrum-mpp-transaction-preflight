# Never use a wallet that holds valuable mainnet assets for this demo.
SERVER_PRIVATE_KEY=0x...
CLIENT_PRIVATE_KEY=0x...

# 42161 = Arbitrum One, 421614 = Arbitrum Sepolia.
CHAIN_ID=42161

# Optional. Omit to use viem's public RPC for the selected chain.
ARBITRUM_RPC=https://arb1.arbitrum.io/rpc

# Raw USDC units. USDC has 6 decimals: 100000 = 0.10 USDC.
PRICE_RAW_USDC=100000
PORT=3000
SERVER_URL=http://localhost:3000

# Local development only. Keep false in production.
ENABLE_FREE_DEMO=false

# Optional x402/Bazaar channel. Requires a Coinbase Developer Platform project.
ENABLE_X402=false
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# Address checked by the example paying client.
TARGET_ADDRESS=0x0000000000000000000000000000000000000000
