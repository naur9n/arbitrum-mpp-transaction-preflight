# Never use a wallet that holds valuable mainnet assets for this demo.
SERVER_PRIVATE_KEY=0x...
CLIENT_PRIVATE_KEY=0x...

# Optional. The public RPC works for light testing, but a dedicated RPC is steadier.
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

# Raw USDC units. USDC has 6 decimals: 1000 = 0.001 USDC.
PRICE_RAW_USDC=1000
PORT=3000
SERVER_URL=http://localhost:3000

# Local development only. Keep false in production.
ENABLE_FREE_DEMO=false

# Address checked by the example paying client.
TARGET_ADDRESS=0x0000000000000000000000000000000000000000
